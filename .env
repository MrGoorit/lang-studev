# ----------------------------------------
# Development environment
# Public runtime variables (exposed to browser via VITE_ prefix)
# ----------------------------------------

# 本地开发服务端口
VITE_PUBLIC_PORT=4233

# 后端 API 基础地址
VITE_PUBLIC_API_BASE_URL=https://jsonplaceholder.typicode.com

# 接口统一前缀（无则留空）
VITE_PUBLIC_API_PREFIX=
